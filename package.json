{
  "name": "newmaker",
  "productName": "Newmaker",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev -p 3001",
    "dev:web": "next dev -p 3001",
    "dev:desktop": "concurrently -k \"npm run dev:web\" \"wait-on tcp:3001 && electron .\"",
    "build": "next build",
    "build:web": "next build",
    "start": "next start",
    "lint": "next lint",
    "dist:win": "npm run build:web && electron-builder --win nsis",
    "dist:portable": "npm run build:web && electron-builder --win portable"
  },
  "dependencies": {
    "@insforge/sdk": "^1.2.2",
    "electron-updater": "^6.6.2",
    "next": "^15.5.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9.21.0",
    "eslint-config-next": "^15.2.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.davronbek.newmaker",
    "productName": "Newmaker",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "out/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Newmaker-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "shortcutName": "Newmaker"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "davronbek-malikov",
        "repo": "News_Maker"
      }
    ]
  }
}
